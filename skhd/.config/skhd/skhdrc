# skhd — omarchy/hyprland-style bindings, alt as SUPER
# (no SIP disable: space *switching* proxies native ctrl+N Mission Control keys)

# go to workspace N  (SUPER+N)
alt - 1 : skhd -k "ctrl - 1"
alt - 2 : skhd -k "ctrl - 2"
alt - 3 : skhd -k "ctrl - 3"
alt - 4 : skhd -k "ctrl - 4"
alt - 5 : skhd -k "ctrl - 5"
alt - 6 : skhd -k "ctrl - 6"

# move window to workspace N  (SUPER+SHIFT+N), follow it there
alt + shift - 1 : yabai -m window --space 1; skhd -k "ctrl - 1"
alt + shift - 2 : yabai -m window --space 2; skhd -k "ctrl - 2"
alt + shift - 3 : yabai -m window --space 3; skhd -k "ctrl - 3"
alt + shift - 4 : yabai -m window --space 4; skhd -k "ctrl - 4"
alt + shift - 5 : yabai -m window --space 5; skhd -k "ctrl - 5"
alt + shift - 6 : yabai -m window --space 6; skhd -k "ctrl - 6"

# focus window  (SUPER=cmd +hjkl); alt+hjkl left free for tmux panes
cmd - h : yabai -m window --focus west
cmd - j : yabai -m window --focus south
cmd - k : yabai -m window --focus north
cmd - l : yabai -m window --focus east

# move/swap window  (SUPER+SHIFT+hjkl / arrows)
alt + shift - h : yabai -m window --swap west
alt + shift - j : yabai -m window --swap south
alt + shift - k : yabai -m window --swap north
alt + shift - l : yabai -m window --swap east
alt + shift - left  : yabai -m window --swap west
alt + shift - down  : yabai -m window --swap south
alt + shift - up    : yabai -m window --swap north
alt + shift - right : yabai -m window --swap east

# fullscreen toggle (SUPER+F — for real this time)
alt - f : yabai -m window --toggle zoom-fullscreen

# float toggle (SUPER+V in omarchy)
alt - v : yabai -m window --toggle float --grid 4:4:1:1:2:2

# rotate / flip layout
alt - r : yabai -m space --rotate 90
alt - x : yabai -m space --mirror x-axis
alt - y : yabai -m space --mirror y-axis

# rebalance splits
alt - e : yabai -m space --balance

# resize focused window (SUPER+ctrl+hjkl)
alt + ctrl - h : yabai -m window --resize left:-50:0 || yabai -m window --resize right:-50:0
alt + ctrl - l : yabai -m window --resize right:50:0 || yabai -m window --resize left:50:0
alt + ctrl - k : yabai -m window --resize top:0:-50 || yabai -m window --resize bottom:0:-50
alt + ctrl - j : yabai -m window --resize bottom:0:50 || yabai -m window --resize top:0:50

# restart yabai (SUPER+SHIFT+R)
alt + shift - r : yabai --restart-service
